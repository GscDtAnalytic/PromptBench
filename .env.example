# =====================================================================
# PromptBench Studio — .env.example
# Copie para .env e preencha. Nada de chaves reais commitadas.
# =====================================================================

# --- Banco e fila ---
DATABASE_URL=postgresql+asyncpg://promptbench:promptbench@postgres:5432/promptbench
DATABASE_URL_SYNC=postgresql+psycopg://promptbench:promptbench@postgres:5432/promptbench
REDIS_URL=redis://redis:6379/0

# Para rodar fora do docker (alembic local, scripts):
# DATABASE_URL=postgresql+asyncpg://promptbench:promptbench@localhost:5432/promptbench
# DATABASE_URL_SYNC=postgresql+psycopg://promptbench:promptbench@localhost:5432/promptbench
# REDIS_URL=redis://localhost:6379/0

# --- Modelos ---
# Provider default usado quando ModelConfig.provider == "fake".
# Valores: fake | claude | openai | gemini
# No MVP roda inteiro com fake; chaves abaixo são opcionais.
MODEL_PROVIDER=fake

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Judge fixo (opcional, recomendado em produção) ---
# Se definidos, o LLM-as-judge usa SEMPRE este provider/model, em vez do mesmo
# modelo do candidato (evita viés de auto-avaliação). Deixe em branco para o
# comportamento legado (judge = modelo do run). Requer a chave do provider.
# JUDGE_PROVIDER=claude
# JUDGE_MODEL=claude-sonnet-4-6

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
